<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Raw Products Views -->
  <record id="view_raw_product_tree" model="ir.ui.view">
    <field name="name">simple_erp.raw_product.tree</field>
    <field name="model">simple_erp.raw_product</field>
    <field name="arch" type="xml">
      <tree string="Raw Products">
        <field name="name" />
        <field name="item_type" />
        <field name="current_qty" />
        <field name="unit_of_measurement" />
        <field name="min_qty" />
      </tree>
    </field>
  </record>

  <!-- Raw Products Action -->
  <record id="action_raw_product" model="ir.actions.act_window">
    <field name="name">Raw Products Stock</field>
    <field name="res_model">simple_erp.raw_product</field>
    <field name="view_mode">tree,form</field>
  </record>

  <!-- Finished Products Views -->
  <record id="view_product_tree" model="ir.ui.view">
    <field name="name">simple_erp.product.tree</field>
    <field name="model">simple_erp.product</field>
    <field name="arch" type="xml">
      <tree string="Finished Products">
        <field name="name" />
      </tree>
    </field>
  </record>

  <!-- Finished Products Action -->
  <record id="action_product" model="ir.actions.act_window">
    <field name="name">Products</field>
    <field name="res_model">simple_erp.product</field>
    <field name="view_mode">tree,form</field>
  </record>

  <!-- Sales CSV Import Views -->
  <record id="view_sales_tree" model="ir.ui.view">
    <field name="name">simple_erp.sales_record.tree</field>
    <field name="model">simple_erp.sales_record</field>
    <field name="arch" type="xml">
      <tree string="Sales Ledger">
        <field name="date" />
        <field name="name" />
        <field name="product_id" />
        <field name="quantity_sold" />
        <field name="income_amount" sum="Total Income" />
      </tree>
    </field>
  </record>

  <!-- Sales Dashboard Graph -->
  <record id="view_sales_graph" model="ir.ui.view">
    <field name="name">simple_erp.sales_record.graph</field>
    <field name="model">simple_erp.sales_record</field>
    <field name="arch" type="xml">
      <graph string="Income Dashboard" type="bar">
        <field name="date" type="row" interval="month" />
        <field name="income_amount" type="measure" />
      </graph>
    </field>
  </record>

  <!-- Sales Action -->
  <record id="action_sales_record" model="ir.actions.act_window">
    <field name="name">Sales Imports</field>
    <field name="res_model">simple_erp.sales_record</field>
    <field name="view_mode">tree,form,graph,pivot</field>
  </record>

  <!-- Sales Dashboard Action -->
  <record id="action_sales_dashboard" model="ir.actions.act_window">
    <field name="name">Sales Dashboard</field>
    <field name="res_model">simple_erp.sales_record</field>
    <field name="view_mode">graph,pivot,tree</field>
    <field name="view_id" ref="view_sales_graph" />
  </record>

  <!-- Invoice Form View to support Image attachment -->
  <record id="view_invoice_form" model="ir.ui.view">
    <field name="name">simple_erp.invoice_record.form</field>
    <field name="model">simple_erp.invoice_record</field>
    <field name="arch" type="xml">
      <form string="Buy Request Entry">
        <sheet>
          <field name="receipt_image" widget="image" class="oe_avatar" />
          <group>
            <group>
              <field name="user_id" />
              <field name="stock_item_id" />
              <field name="request_date" />
              <field name="done_date" />
            </group>
            <group>
              <field name="status" />
              <field name="qty" />
              <field name="unit_price" />
              <field name="amount_total" />
            </group>
          </group>
          <group>
            <field name="note" />
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Invoice Tree View -->
  <record id="view_invoice_tree" model="ir.ui.view">
    <field name="name">simple_erp.invoice_record.tree</field>
    <field name="model">simple_erp.invoice_record</field>
    <field name="arch" type="xml">
      <tree string="Buy Requests">
        <field name="request_date" />
        <field name="user_id" />
        <field name="stock_item_id" />
        <field name="status" />
        <field name="qty" />
        <field name="amount_total" sum="Total Expense" />
      </tree>
    </field>
  </record>

  <!-- Invoice Dashboard Graph -->
  <record id="view_invoice_graph" model="ir.ui.view">
    <field name="name">simple_erp.invoice_record.graph</field>
    <field name="model">simple_erp.invoice_record</field>
    <field name="arch" type="xml">
      <graph string="Buy Request Dashboard" type="bar">
        <field name="request_date" type="row" interval="month" />
        <field name="amount_total" type="measure" />
      </graph>
    </field>
  </record>

  <!-- Invoices Action -->
  <record id="action_invoice_record" model="ir.actions.act_window">
    <field name="name">Invoices Upload</field>
    <field name="res_model">simple_erp.invoice_record</field>
    <field name="view_mode">tree,form,graph,pivot</field>
  </record>

  <!-- Expense Dashboard Action -->
  <record id="action_invoice_dashboard" model="ir.actions.act_window">
    <field name="name">Expense Dashboard</field>
    <field name="res_model">simple_erp.invoice_record</field>
    <field name="view_mode">graph,pivot,tree</field>
    <field name="view_id" ref="view_invoice_graph" />
  </record>

  <!-- Unified Dashboard Metrics Views -->
  <record id="view_dashboard_metrics_tree" model="ir.ui.view">
    <field name="name">simple_erp.dashboard_metrics.tree</field>
    <field name="model">simple_erp.dashboard_metrics</field>
    <field name="arch" type="xml">
      <tree string="Dashboard Metrics" create="false" edit="false" delete="false">
        <field name="date" />
        <field name="income_amount" sum="Income" />
        <field name="expense_amount" sum="Expense" />
        <field name="net_total_amount" sum="Net Total" />
        <field name="stock_in_amount" sum="Stock In" />
        <field name="stock_out_amount" sum="Stock Out" />
      </tree>
    </field>
  </record>

  <record id="view_dashboard_finance_graph" model="ir.ui.view">
    <field name="name">simple_erp.dashboard_metrics.finance.graph</field>
    <field name="model">simple_erp.dashboard_finance_line</field>
    <field name="arch" type="xml">
      <graph string="Income vs Expense vs Net Total" type="line">
        <field name="date" type="row" interval="month" />
        <field name="metric" type="col" />
        <field name="amount" type="measure" />
      </graph>
    </field>
  </record>

  <record id="view_stock_change_log_tree" model="ir.ui.view">
    <field name="name">simple_erp.stock_change_log.tree</field>
    <field name="model">simple_erp.stock_change_log</field>
    <field name="arch" type="xml">
      <tree string="Stock Change History" create="false" edit="false" delete="false">
        <field name="changed_at" />
        <field name="source" />
        <field name="reference" />
        <field name="product_id" />
        <field name="raw_product_id" />
        <field name="change_amount" sum="Net Change" />
        <field name="stock_in_amount" sum="Stock In" />
        <field name="stock_out_amount" sum="Stock Out" />
        <field name="resulting_stock" />
      </tree>
    </field>
  </record>

  <record id="view_sales_dashboard_search" model="ir.ui.view">
    <field name="name">simple_erp.sales_record.dashboard.search</field>
    <field name="model">simple_erp.sales_record</field>
    <field name="arch" type="xml">
      <search string="Sales Dashboard Filters">
        <filter string="Date" name="sales_date_filter" date="date" />
        <separator />
        <filter string="Today" name="sales_today" domain="[('date', '=', context_today())]" />
        <filter string="This Month" name="sales_this_month"
          domain="[('date', '&gt;=', context_today().strftime('%%Y-%%m-01')), ('date', '&lt;=', context_today())]" />
        <filter string="Last 30 Days" name="sales_last_30"
          domain="[('date', '&gt;=', context_today() - relativedelta(days=30)), ('date', '&lt;=', context_today())]" />
        <filter string="Last 90 Days" name="sales_last_90"
          domain="[('date', '&gt;=', context_today() - relativedelta(days=90)), ('date', '&lt;=', context_today())]" />
        <filter string="This Year" name="sales_this_year"
          domain="[('date', '&gt;=', context_today().strftime('%%Y-01-01')), ('date', '&lt;=', context_today())]" />
      </search>
    </field>
  </record>

  <record id="view_invoice_dashboard_search" model="ir.ui.view">
    <field name="name">simple_erp.invoice_record.dashboard.search</field>
    <field name="model">simple_erp.invoice_record</field>
    <field name="arch" type="xml">
      <search string="Expense Dashboard Filters">
        <filter string="Date" name="invoice_date_filter" date="request_date" />
        <separator />
        <filter string="Today" name="invoice_today"
          domain="[('request_date', '=', context_today())]" />
        <filter string="This Month" name="invoice_this_month"
          domain="[('request_date', '&gt;=', context_today().strftime('%%Y-%%m-01')), ('request_date', '&lt;=', context_today())]" />
        <filter string="Last 30 Days" name="invoice_last_30"
          domain="[('request_date', '&gt;=', context_today() - relativedelta(days=30)), ('request_date', '&lt;=', context_today())]" />
        <filter string="Last 90 Days" name="invoice_last_90"
          domain="[('request_date', '&gt;=', context_today() - relativedelta(days=90)), ('request_date', '&lt;=', context_today())]" />
        <filter string="This Year" name="invoice_this_year"
          domain="[('request_date', '&gt;=', context_today().strftime('%%Y-01-01')), ('request_date', '&lt;=', context_today())]" />
      </search>
    </field>
  </record>

  <record id="view_stock_dashboard_search" model="ir.ui.view">
    <field name="name">simple_erp.stock_change_log.dashboard.search</field>
    <field name="model">simple_erp.stock_change_log</field>
    <field name="arch" type="xml">
      <search string="Stock Dashboard Filters">
        <filter string="Date" name="stock_date_filter" date="changed_at" />
        <separator />
        <filter string="Today" name="stock_today"
          domain="[('changed_at', '&gt;=', context_today())]" />
        <filter string="Last 30 Days" name="stock_last_30"
          domain="[('changed_at', '&gt;=', context_today() - relativedelta(days=30)), ('changed_at', '&lt;=', context_today())]" />
        <filter string="Last 90 Days" name="stock_last_90"
          domain="[('changed_at', '&gt;=', context_today() - relativedelta(days=90)), ('changed_at', '&lt;=', context_today())]" />
        <filter string="This Year" name="stock_this_year"
          domain="[('changed_at', '&gt;=', context_today().strftime('%%Y-01-01')), ('changed_at', '&lt;=', context_today())]" />
      </search>
    </field>
  </record>

  <record id="view_finance_dashboard_search" model="ir.ui.view">
    <field name="name">simple_erp.dashboard_finance_line.dashboard.search</field>
    <field name="model">simple_erp.dashboard_finance_line</field>
    <field name="arch" type="xml">
      <search string="Finance Dashboard Filters">
        <filter string="Date" name="finance_date_filter" date="date" />
        <field name="metric" />
        <separator />
        <filter string="Today" name="finance_today" domain="[('date', '=', context_today())]" />
        <filter string="This Month" name="finance_this_month"
          domain="[('date', '&gt;=', context_today().strftime('%%Y-%%m-01')), ('date', '&lt;=', context_today())]" />
        <filter string="Last 30 Days" name="finance_last_30"
          domain="[('date', '&gt;=', context_today() - relativedelta(days=30)), ('date', '&lt;=', context_today())]" />
        <filter string="Last 90 Days" name="finance_last_90"
          domain="[('date', '&gt;=', context_today() - relativedelta(days=90)), ('date', '&lt;=', context_today())]" />
        <filter string="This Year" name="finance_this_year"
          domain="[('date', '&gt;=', context_today().strftime('%%Y-01-01')), ('date', '&lt;=', context_today())]" />
      </search>
    </field>
  </record>

  <!-- Attach dashboard search views after their XML IDs are defined -->
  <record id="action_sales_dashboard" model="ir.actions.act_window">
    <field name="search_view_id" ref="view_sales_dashboard_search" />
  </record>

  <record id="action_invoice_dashboard" model="ir.actions.act_window">
    <field name="search_view_id" ref="view_invoice_dashboard_search" />
  </record>

  <record id="view_dashboard_stock_graph" model="ir.ui.view">
    <field name="name">simple_erp.stock_change_log.graph</field>
    <field name="model">simple_erp.stock_change_log</field>
    <field name="arch" type="xml">
      <graph string="Total Stock Changes" type="line">
        <field name="changed_at" type="row" interval="day" />
        <field name="stock_in_amount" type="measure" />
        <field name="stock_out_amount" type="measure" />
      </graph>
    </field>
  </record>

  <record id="action_finance_dashboard" model="ir.actions.act_window">
    <field name="name">Income vs Expense</field>
    <field name="res_model">simple_erp.dashboard_finance_line</field>
    <field name="view_mode">graph,pivot</field>
    <field name="view_id" ref="view_dashboard_finance_graph" />
    <field name="search_view_id" ref="view_finance_dashboard_search" />
  </record>

  <record id="action_stock_change_dashboard" model="ir.actions.act_window">
    <field name="name">Total Stock Changes</field>
    <field name="res_model">simple_erp.stock_change_log</field>
    <field name="view_mode">graph,pivot,tree</field>
    <field name="view_id" ref="view_dashboard_stock_graph" />
    <field name="search_view_id" ref="view_stock_dashboard_search" />
  </record>

  <!-- Bridge built-in HR app pages into ERP menu without changing their core behavior -->
  <record id="action_erp_employees" model="ir.actions.act_window">
    <field name="name">Employees</field>
    <field name="res_model">hr.employee</field>
    <field name="view_mode">kanban,tree,form</field>
  </record>

  <record id="action_erp_attendance" model="ir.actions.act_window">
    <field name="name">Attendance</field>
    <field name="res_model">hr.attendance</field>
    <field name="view_mode">tree,form,graph,pivot</field>
  </record>

  <!-- Main Menus -->
  <menuitem id="menu_erp_root" name="Business ERP" sequence="10" />

  <menuitem id="menu_erp_dashboard" name="Dashboard" parent="menu_erp_root" sequence="1" />
  <menuitem id="menu_erp_sales_dashboard" name="Sales Overview" parent="menu_erp_dashboard"
    action="action_sales_dashboard" sequence="1" />
  <menuitem id="menu_erp_expense_dashboard" name="Expense Overview" parent="menu_erp_dashboard"
    action="action_invoice_dashboard" sequence="2" />
  <menuitem id="menu_erp_stock_change_dashboard" name="Stock Changes" parent="menu_erp_dashboard"
    action="action_stock_change_dashboard" sequence="3" />
  <menuitem id="menu_erp_finance_dashboard" name="Income vs Expense" parent="menu_erp_dashboard"
    action="action_finance_dashboard" sequence="4" />

  <menuitem id="menu_erp_raw_products" name="Stock" parent="menu_erp_root"
    action="action_raw_product" sequence="2" />
  <menuitem id="menu_erp_products" name="Product" parent="menu_erp_root" action="action_product"
    sequence="3" />
  <menuitem id="menu_erp_sales" name="Sales CSV Reader" parent="menu_erp_root"
    action="action_sales_record" sequence="4" />
  <menuitem id="menu_erp_invoices" name="Invoice Upload" parent="menu_erp_root"
    action="action_invoice_record" sequence="5" />
  <menuitem id="menu_erp_employees" name="Employees" parent="menu_erp_root"
    action="action_erp_employees" sequence="6" />
  <menuitem id="menu_erp_attendance" name="Attendance" parent="menu_erp_root"
    action="action_erp_attendance" sequence="7" />

</odoo>